/* app.wxss - 全局样式 V3.0 (微信官方设计规范优化版)
 * 智机惠小程序
 * 优化：字体规范、颜色对比度、按钮热区、操作反馈、无障碍支持
 * 参考：https://developers.weixin.qq.com/miniprogram/en/design/
 */

/* ========== 页面基础（微信设计规范） ========== */
page {
  background-color: #F5F7FA;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  /* 微信推荐字体层级：17pt(34rpx) 正文、15pt(30rpx) 次要、14pt(28rpx) 辅助、12pt(24rpx) 标签 */
  font-size: 34rpx;
  color: #333333;
  /* 增强可访问性 */
  -webkit-tap-highlight-color: transparent;
  -webkit-touch-callout: none;
  user-select: none;
}

/* ========== 无障碍：增加焦点指示器 ========== */
button:focus-visible,
view:focus-visible {
  outline: 4rpx solid #1677FF;
  outline-offset: 2rpx;
}

/* ========== 通用卡片 V3.0 ========== */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: box-shadow 0.2s ease, transform 0.2s ease;
}

/* 微信规范：卡片点击态 */
.card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.06);
}

/* ========== 输入框聚焦与校验态 ========== */
.input-wrapper {
  position: relative;
}

/* 输入框焦点态：边框高亮 */
t-input.input-focus .t-input__wrapper,
.input-wrapper.input-focus .t-input__wrapper {
  border-color: #1677FF !important;
  box-shadow: 0 0 0 4rpx rgba(22, 119, 255, 0.1) !important;
  background-color: #FFFFFF !important;
}

t-input.input-focus,
.input-wrapper.input-focus {
  opacity: 1;
}

/* 输入框错误态：红色边框 + 抖动提示 */
t-input.input-error .t-input__wrapper,
.input-wrapper.input-error .t-input__wrapper {
  border: 2rpx solid #FF4D4F !important;
  background-color: #FFF5F5 !important;
  animation: shake 0.4s ease-in-out;
}

t-input.input-error,
.input-wrapper.input-error {
  opacity: 1;
  animation: shake 0.4s ease-in-out;
}

/* 抖动动画 */
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-6rpx); }
  20%, 40%, 60%, 80% { transform: translateX(6rpx); }
}

/* 输入框成功态 */
.input-success {
  border-color: #52C41A !important;
  background-color: #F6FFED !important;
}

/* ========== 按钮热区优化（微信规范：7-9mm热区） ========== */
/* 主色按钮 - 增强点击区域 */
.btn-primary {
  background: linear-gradient(135deg, #1677FF 0%, #0051D4 100%);
  color: #FFFFFF;
  border-radius: 100rpx;
  font-size: 34rpx;
  font-weight: 600;
  min-height: 96rpx;
  padding: 24rpx 48rpx;
  line-height: 1.4;
  text-align: center;
  border: none;
  box-shadow: 0 8rpx 16rpx rgba(22, 119, 255, 0.2);
  transition: transform 0.15s ease, opacity 0.15s ease, box-shadow 0.15s ease;
  /* 微信规范：增大热区 */
  margin: 16rpx 0;
}

/* 微信规范：按钮按下态 */
.btn-primary:active {
  transform: scale(0.96);
  opacity: 0.9;
  box-shadow: 0 4rpx 8rpx rgba(22, 119, 255, 0.15);
}

/* 次级按钮 */
.btn-secondary {
  background: #FFFFFF;
  color: #1677FF;
  border: 2rpx solid #1677FF;
  border-radius: 100rpx;
  font-size: 34rpx;
  min-height: 88rpx;
  padding: 20rpx 40rpx;
  line-height: 1.4;
  text-align: center;
  transition: all 0.15s ease;
}

.btn-secondary:active {
  background: rgba(22, 119, 255, 0.08);
  transform: scale(0.96);
}

/* 微信规范：文字按钮（无背景） */
.btn-text {
  color: #1677FF;
  font-size: 34rpx;
  padding: 16rpx 24rpx;
  background: transparent;
  border: none;
  min-height: auto;
}

.btn-text:active {
  opacity: 0.6;
}

/* ========== 颜色系统（微信规范：对比度清晰） ========== */
.color-success { color: #07C160; }
.color-warning { color: #FFB800; }
.color-error { color: #FA5151; }
.color-primary { color: #1677FF; }
.color-grey { color: #999999; }
.color-muted { color: #666666; }

/* 背景色状态 */
.bg-success { background-color: #E8F8EF; }
.bg-warning { background-color: #FFF8E6; }
.bg-error { background-color: #FFEDED; }
.bg-primary { background-color: #E6F0FF; }

/* ========== 分割线（微信规范：1px边框） ========== */
.divider {
  height: 1rpx;
  background: #E5E5E5;
  margin: 24rpx 0;
}

.divider-vertical {
  width: 1rpx;
  height: 100%;
  background: #E5E5E5;
  margin: 0 24rpx;
}

/* ========== 页面标题（微信字体层级规范） ========== */
.page-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 8rpx;
  line-height: 1.3;
}

.page-subtitle {
  font-size: 30rpx;
  color: #666666;
  line-height: 1.5;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.section-desc {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.5;
}

/* 微信规范：辅助文字层级 */
.text-primary { font-size: 34rpx; color: #333333; }
.text-secondary { font-size: 30rpx; color: #666666; }
.text-tertiary { font-size: 28rpx; color: #999999; }
.text-caption { font-size: 24rpx; color: #999999; }

/* ========== 加载状态（微信规范：避免长时间白屏） ========== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
  margin-top: 24rpx;
}

/* 骨架屏动画 */
.skeleton {
  background: linear-gradient(90deg, #F5F5F5 25%, #EAEAEA 50%, #F5F5F5 75%);
  background-size: 400% 100%;
  animation: skeleton-loading 1.5s ease infinite;
  border-radius: 8rpx;
}

@keyframes skeleton-loading {
  0% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* 加载点动画 */
.loading-dots {
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #1677FF;
  margin: 0 8rpx;
  animation: dotPulse 1.2s ease-in-out infinite;
}

.loading-dot:nth-child(2) { animation-delay: 0.15s; }
.loading-dot:nth-child(3) { animation-delay: 0.3s; }

@keyframes dotPulse {
  0%, 80%, 100% { transform: scale(0.7); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

/* ========== 渐变背景 ========== */
.bg-gradient-primary {
  background: linear-gradient(135deg, #1677FF 0%, #0051D4 100%);
}

.bg-gradient-light {
  background: linear-gradient(180deg, #F8FAFF 0%, #FFFFFF 100%);
}

/* ========== 状态徽章（微信规范：简洁明确） ========== */
.status-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.2;
}

.status-badge-default {
  background: #F0F0F0;
  color: #666666;
}

.status-badge-process {
  background: #E6F4FF;
  color: #1677FF;
}

.status-badge-success {
  background: #E8F8EF;
  color: #07C160;
}

.status-badge-warning {
  background: #FFF8E6;
  color: #B78A00;
}

.status-badge-error {
  background: #FFEDED;
  color: #FA5151;
}

/* ========== 可点击元素反馈 ========== */
.touch-active {
  transition: opacity 0.15s ease;
}

.touch-active:active {
  opacity: 0.7;
}

/* 列表项点击态 */
.list-item {
  background: #FFFFFF;
  transition: background-color 0.15s ease;
}

.list-item:active {
  background-color: #F5F5F5;
}

/* ========== 表单规范 ========== */
.form-error-tip {
  font-size: 24rpx;
  color: #FA5151;
  margin-top: 8rpx;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.form-label {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 12rpx;
  display: block;
}

.form-hint {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* ========== TDesign 组件适配（微信规范） ========== */
t-input {
  --td-input-border-radius: 16rpx;
  --td-input-bg-color: #F8F8F8;
  --td-input-font-size: 34rpx;
  --td-input-label-font-size: 30rpx;
}

t-button {
  --td-button-border-radius: 100rpx;
  --td-button-medium-font-size: 32rpx;
}

.tab-panel-content {
  padding: 24rpx;
  padding-bottom: 180rpx;
}

t-steps {
  --td-step-dot-size: 16rpx;
}

t-tabs {
  --td-tab-nav-bg-color: #FFFFFF;
  --td-tab-font-size: 30rpx;
}

/* 微信规范：Dialog 圆角 */
t-dialog {
  --td-dialog-border-radius: 24rpx;
}

/* 微信规范：Popup 圆角 */
t-popup {
  --td-popup-border-radius: 24rpx;
}

/* ========== 底部安全区适配 ========== */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-area-top {
  padding-top: env(safe-area-inset-top);
}

/* ========== 空状态（微信规范：提供解决方案） ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-state-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.empty-state-text {
  font-size: 30rpx;
  color: #999999;
  text-align: center;
  margin-bottom: 24rpx;
}

.empty-state-action {
  font-size: 30rpx;
  color: #1677FF;
}

/* ========== Toast 提示（微信规范：清晰明确） ========== */
.t-toast {
  --td-toast-max-width: 400rpx;
}

/* ========== 减少动画（无障碍支持） ========== */
/* 微信小程序不支持 @media prefers-reduced-motion，此处注释保留 */
/* 可在具体动画处使用 animation-play-state 控制 */
