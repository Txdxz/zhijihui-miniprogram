.skeleton {
  padding: 32rpx;
}

.skeleton--animate .skeleton-item {
  background: linear-gradient(90deg, #f2f2f2 25%, #e6e6e6 37%, #f2f2f2 63%);
  background-size: 400% 100%;
  animation: skeleton-loading 1.4s ease infinite;
}

@keyframes skeleton-loading {
  0% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0 50%;
  }
}

.skeleton-item {
  height: 32rpx;
  background: #f2f2f2;
  border-radius: 8rpx;
}

/* 卡片骨架 */
.skeleton-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.skeleton-card__header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.skeleton-card__avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.skeleton-card__title {
  flex: 1;
}

/* 列表骨架 */
.skeleton-list-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: #fff;
  margin-bottom: 2rpx;
}

.skeleton-list-item__icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
}

.skeleton-list-item__content {
  flex: 1;
}

/* 文本骨架 */
.skeleton-text {
  padding: 24rpx;
}
