<view class="page">
  <!-- 骨架屏 -->
  <skeleton wx:if="{{pageLoading}}" loading="{{pageLoading}}" type="card" item-count="2" />

  <!-- 错误状态 -->
  <view wx:elif="{{pageError}}" class="error-state">
    <view class="error-state__icon">⚠️</view>
    <text class="error-state__text">{{pageError}}</text>
    <button class="retry-btn" bindtap="onPullDownRefresh" size="mini">重试</button>
  </view>

  <block wx:else>
  <view class="hero">
    <text class="hero-title">我的卡包</text>
    <text class="hero-sub">在移动权益平台领取后，代金券将自动到账</text>
  </view>

  <view class="sheet" wx:if="{{!hasContract}}">
    <van-empty description="暂无代金券，请在移动权益平台领取后再查看">
      <van-button type="primary" size="small" round custom-class="empty-btn" bind:click="goToIndex">返回首页</van-button>
    </van-empty>
  </view>

  <block wx:if="{{hasContract}}">
    <view class="sheet summary-sheet first-sheet">
      <view class="summary-grid">
        <view class="summary-col">
          <text class="summary-num num-ok">{{availableCount}}</text>
          <text class="summary-label">可使用</text>
        </view>
        <van-divider vertical custom-class="summary-vdiv" />
        <view class="summary-col">
          <text class="summary-num num-muted">{{usedCount}}</text>
          <text class="summary-label">已使用</text>
        </view>
        <van-divider vertical custom-class="summary-vdiv" />
        <view class="summary-col">
          <text class="summary-num num-muted">{{totalCount}}</text>
          <text class="summary-label">共 {{totalCount}} 张</text>
        </view>
      </view>
    </view>

    <view class="sheet list-sheet">
      <view class="coupon-item {{item.statusClass}}" wx:for="{{coupons}}" wx:key="id">
        <view class="coupon-left">
          <view class="coupon-amount">
            <text class="coupon-yen">¥</text>
            <text class="coupon-num">{{item.amount}}</text>
          </view>
          <text class="coupon-store">限【{{item.storeName || '所有适用门店'}}】使用</text>
        </view>
        <view class="coupon-right">
          <text class="coupon-expire">有效期至 {{item.expireDate}}</text>
          <view class="coupon-status-box available" wx:if="{{item.status === 1}}">
            <text class="status-text">可使用</text>
            <text class="status-hint">到店出示给店员</text>
            <van-button type="danger" size="small" round custom-class="use-btn" bind:click="showVerifyCode" data-id="{{item.id}}">立即使用</van-button>
          </view>
          <view class="coupon-status-box used" wx:if="{{item.status === 2}}">
            <text class="status-text used">已核销</text>
          </view>
          <view class="coupon-status-box expired" wx:if="{{item.status === 3}}">
            <text class="status-text">已过期</text>
          </view>
        </view>
      </view>
    </view>

    <view class="sheet tips-sheet">
      <view class="benefit-content">
        <text class="benefit-label">权益内容</text>
        <text class="benefit-text">宠物门店服务类商品代金券一张</text>
      </view>
      <text class="tips-title">使用说明</text>
      <view class="tips-list">
        <view class="tips-item">
          <text class="tips-num">1</text>
          <text class="tips-text">领取权益：用户订购权益成功后，在【河北移动权益优选】小程序页面，点击我的-我的订单或点击链接 https://dx.10086.cn/0oqmu6Rz 至微信小程序打开，找到订单页点击【去使用】，点击优惠券即可领取优惠</text>
        </view>
        <view class="tips-item">
          <text class="tips-num">2</text>
          <text class="tips-text">兑换权益：领取优惠券后，微信搜索【智机惠】小程序，使用权益领取手机号登录，点击我的卡包，点击优惠券向店员核销使用</text>
        </view>
        <view class="tips-item">
          <text class="tips-num">3</text>
          <text class="tips-text">使用权益：到店后点击「立即使用」获取核销码，向店员出示即可</text>
        </view>
        <view class="tips-item">
          <text class="tips-num">4</text>
          <text class="tips-text">代金券自领取到账之日起当月有效，当月未领取自动失效，不可转赠他人，请在有效期内使用，过期不补</text>
        </view>
        <view class="tips-item">
          <text class="tips-num">5</text>
          <text class="tips-text">单次限用一张券，本优惠为虚拟产品一经领取，不退不换、不兑现、不找零、不可拆分使用，请您核对好后再行领取</text>
        </view>
        <view class="tips-item">
          <text class="tips-num">6</text>
          <text class="tips-text">该产品一旦下发不支持退换，请您领取使用前先致电商家详询具体可使用的商品/服务范围、是否需要预约等内容，以商家解释为准，以免无法使用造成不必要的损失</text>
        </view>
        <view class="tips-item">
          <text class="tips-num">7</text>
          <view class="store-list">
            <text class="tips-text store-title">适用门店：</text>
            <text class="tips-text store-item">猫庄宠物用品超市(众创大厦店)、</text>
            <text class="tips-text store-item">裕华小甄宠物用品店、</text>
            <text class="tips-text store-item">猫庄·宠物生活馆、</text>
            <text class="tips-text store-item">小鹿宠物(盛邦花园六区店)、</text>
            <text class="tips-text store-item">有猫腻宠物生活馆、</text>
            <text class="tips-text store-item">芊宠萌宠物服务、</text>
            <text class="tips-text store-item">安淇宠物医院（秦皇岛店）</text>
          </view>
        </view>
      </view>
    </view>

    <view class="sheet service-sheet">
      <text class="service-title">客服电话</text>
      <text class="service-phone" bindtap="callCustomerService">4007071506</text>
      <text class="service-time">服务时间：09:00-17:30（周一至周五）</text>
    </view>
  </block>

  <view class="tabbar-spacer" />

  <van-popup
    show="{{ showModal }}"
    round
    position="center"
    closeable
    close-icon-position="top-right"
    custom-class="verify-popup"
    bind:close="hideModal"
    lock-scroll="{{true}}"
  >
    <view class="modal-inner" catchtouchmove="preventBubble" catchtap="preventBubble">
      <text class="modal-title">出示核销码</text>
      <text class="verify-tip">请将二维码对准扫码设备，有效期内使用</text>
      <view class="qrcode-wrapper" catchtouchmove="preventBubble">
        <canvas
          canvas-id="qrcode-canvas"
          class="qrcode-canvas"
          style="width: 200px; height: 200px;"
        />
      </view>
      <view class="code-row">
        <text class="code-number">{{verifyCode}}</text>
        <van-tag type="{{countdown < 60 ? 'warning' : 'primary'}}" plain size="medium">{{countdownText}}</van-tag>
      </view>
      <text class="code-hint" wx:if="{{countdown < 60}}">即将过期，可点击下方刷新</text>
      <van-cell-group inset custom-class="modal-cells">
        <van-cell title="券面额" value="¥{{currentCoupon.amount}}" />
        <van-cell title="适用门店" value="{{currentCoupon.storeName}}" />
      </van-cell-group>
      <van-button
        type="{{countdown < 60 ? 'warning' : 'primary'}}"
        block
        round
        plain="{{countdown >= 60}}"
        loading="{{ regenerating }}"
        bind:click="regenerateCode"
      >{{countdown < 60 ? '即将过期，重新生成' : '刷新核销码'}}</van-button>
    </view>
  </van-popup>

  <van-toast id="van-toast" />
  </block>
</view>
