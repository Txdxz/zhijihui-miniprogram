.bind-container {
  min-height: 100vh;
  background: #F5F7FA;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

.bind-header {
  text-align: center;
  margin-bottom: 60rpx;
  padding-top: 60rpx;
}

.bind-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.bind-title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.bind-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.bind-form {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #F5F7FA;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  box-sizing: border-box;
}

.native-input {
  line-height: 88rpx;
}

.error-message {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #ee0a24;
}

.error-tip {
  background: #FFF5F5;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.error-tip text {
  font-size: 26rpx;
  color: #FF4D4F;
}

.bind-btn {
  width: 100%;
  height: 88rpx;
  background: #1677FF;
  border-radius: 12rpx;
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
  border: none;
}

.bind-btn[disabled] {
  background: #B3D4FF;
}

.result-box {
  text-align: center;
  padding: 60rpx 0;
}

.result-icon {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  border-radius: 50%;
  font-size: 60rpx;
  margin: 0 auto 32rpx;
}

.result-icon.success {
  background: #E6F7EE;
  color: #07C160;
}

.result-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.result-tip {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.bind-footer {
  text-align: center;
  margin-top: 60rpx;
}

.footer-tip {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.footer-link {
  display: inline-block;
  font-size: 28rpx;
  color: #1677FF;
}
