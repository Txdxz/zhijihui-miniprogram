.launch-page {
  min-height: 100vh;
  padding: 56rpx 24rpx 40rpx;
  background:
    radial-gradient(circle at top right, rgba(64, 132, 255, 0.22), transparent 34%),
    linear-gradient(180deg, #f1f6ff 0%, #f7f9fc 46%, #eef3fb 100%);
  box-sizing: border-box;
}

.hero {
  padding: 28rpx 12rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.brand-badge {
  min-width: 224rpx;
  height: 96rpx;
  padding: 0 26rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #1677ff 0%, #0051d4 100%);
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 40rpx rgba(22, 119, 255, 0.22);
  letter-spacing: 2rpx;
  box-sizing: border-box;
}

.brand-name {
  margin-top: 28rpx;
  font-size: 52rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #102a56;
}

.brand-slogan {
  margin-top: 18rpx;
  font-size: 30rpx;
  line-height: 1.7;
  font-weight: 600;
  color: #1f3f74;
}

.panel {
  padding: 36rpx 28rpx 32rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(18, 73, 164, 0.08);
  border-radius: 28rpx;
  box-shadow: 0 16rpx 48rpx rgba(16, 42, 86, 0.1);
  backdrop-filter: blur(10rpx);
}

.identity-card {
  margin-bottom: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, rgba(22, 119, 255, 0.08), rgba(22, 119, 255, 0.02));
  display: flex;
  align-items: center;
}

.identity-card.muted {
  background: linear-gradient(135deg, rgba(15, 23, 42, 0.05), rgba(15, 23, 42, 0.02));
}

.identity-avatar,
.identity-placeholder {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.identity-placeholder {
  background: #d9e6ff;
  color: #0f3d91;
  font-size: 38rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.identity-meta {
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.identity-name {
  font-size: 30rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #102a56;
}

.identity-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #71819c;
}

.status-box {
  min-height: 88rpx;
  padding: 0 8rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.status-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: #4d5f7c;
  text-align: center;
}

.panel-note {
  display: block;
  margin-top: 22rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #8a98af;
  text-align: center;
}

.popup-card {
  padding: 34rpx 28rpx calc(34rpx + env(safe-area-inset-bottom));
}

.popup-title {
  display: block;
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #102a56;
}

.popup-desc {
  display: block;
  margin-top: 12rpx;
  margin-bottom: 26rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #6d7f99;
}

.role-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.role-option {
  padding: 24rpx;
  border-radius: 22rpx;
  background: #f5f8ff;
  border: 1rpx solid rgba(22, 119, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.role-option::after {
  border: none;
}

.role-option-main {
  display: flex;
  flex-direction: column;
  text-align: left;
}

.role-option-title {
  font-size: 30rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #102a56;
}

.role-option-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #71819c;
}

.role-option-arrow {
  font-size: 38rpx;
  line-height: 1;
  color: #7d92b7;
}

.bind-entry {
  margin-top: 24rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.bind-tip {
  font-size: 26rpx;
  color: #8a98af;
}

.bind-link {
  font-size: 26rpx;
  color: #1677FF;
}
