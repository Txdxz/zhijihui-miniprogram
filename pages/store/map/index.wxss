/* pages/store/map/index.wxss */

page {
  height: 100vh;
  overflow: hidden;
}

.map-view {
  width: 100%;
  height: 100vh;
}

.map-empty-tip {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  transform: translateY(-50%);
  text-align: center;
  padding: 48rpx;
}

.empty-text {
  display: block;
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-sub {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.store-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.12);
  z-index: 1000;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.panel-handle {
  width: 48rpx;
  height: 8rpx;
  background: #ddd;
  border-radius: 4rpx;
  margin: 16rpx auto 12rpx;
}

.panel-content {
  padding: 0 32rpx 24rpx;
}

.panel-name {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.panel-addr {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.panel-distance {
  display: inline-block;
  background: #E6F0FF;
  border-radius: 8rpx;
  padding: 6rpx 16rpx;
  margin-bottom: 16rpx;
}

.panel-distance-text {
  font-size: 26rpx;
  color: #1677FF;
  font-weight: 600;
}

.panel-tip {
  display: block;
  font-size: 28rpx;
  color: #1677FF;
  font-weight: 500;
  text-align: right;
}
