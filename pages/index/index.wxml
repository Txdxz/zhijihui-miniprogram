<view class="container">
  <!-- 骨架屏加载状态 -->
  <skeleton wx:if="{{pageLoading}}" loading="{{pageLoading}}" type="card" item-count="2" />

  <!-- 错误状态 -->
  <view wx:elif="{{pageError}}" class="error-state">
    <view class="error-state__icon">⚠️</view>
    <text class="error-state__text">{{pageError}}</text>
    <view class="error-state__actions">
      <button class="retry-btn" bindtap="onPullDownRefresh" size="mini">重试</button>
    </view>
  </view>

  <!-- 正常内容 -->
  <block wx:else>
  <!-- 顶部品牌区域 -->
  <view class="header">
    <!-- 用户信息区 -->
    <view class="user-bar">
      <view class="user-info" wx:if="{{isLoggedIn && userInfo}}" bindtap="goToProfile">
        <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
        <text class="user-nickname">{{userInfo.nickName}}</text>
        <text class="profile-arrow">›</text>
      </view>
      <button
        wx:if="{{!isLoggedIn}}"
        class="login-btn"
        bindtap="onTriggerLogin"
        plain
      >
        <text class="login-btn-text">登录</text>
      </button>
    </view>
    <view class="brand">
      <text class="brand-name">智机惠</text>
      <text class="brand-slogan">全场景聚合服务，让每一次选择更值。</text>
    </view>
  </view>

  <!-- 门店信息卡片（扫码带入 + 定位匹配） -->
  <view class="store-card" wx:if="{{storeInfo.name}}">
    <view class="store-card-header">
      <view class="store-badge">{{storeInfo.distanceText ? '最近门店' : '当前门店'}}</view>
      <view class="store-header-right">
        <!-- 定位按钮 -->
        <view class="location-refresh-btn" bindtap="onGetLocation">
          <text class="location-refresh-icon">📍</text>
          <text class="location-refresh-text">{{locationText === '正在获取位置...' ? '定位中' : '重新定位'}}</text>
        </view>
        <view class="store-distance" wx:if="{{storeInfo.distanceText}}">
          <text class="distance-text">{{storeInfo.distanceText}}</text>
        </view>
      </view>
    </view>
    <view class="store-name">{{storeInfo.name}}</view>
    <view class="store-addr">{{storeInfo.address}}</view>
    <!-- 切换门店按钮（当有多个门店时显示） -->
    <view class="switch-store-btn" bindtap="onSwitchStore" wx:if="{{stores.length > 1}}">
      <text class="switch-store-text">切换门店 ({{stores.length}}家可选)</text>
      <text class="switch-store-arrow">›</text>
    </view>
    <!-- 查看附近门店地图 -->
    <view class="store-map-link" bindtap="goToStoreMap" wx:if="{{stores.length > 0}}">
      <text class="store-map-text">查看附近门店地图</text>
      <text class="store-map-arrow">›</text>
    </view>
  </view>

  <!-- 合约办理进度 -->
  <view class="card progress-card">
    <view class="card-title-row">
      <view class="card-title">合约办理进度</view>
      <!-- 只在合约已完成时显示"新办业务"按钮 -->
      <view 
        class="new-contract-btn" 
        bindtap="onCreateNewContract" 
        wx:if="{{contractStatus >= 5 && contractStatus <= 7}}"
      >
        <text class="new-contract-text">新办业务</text>
      </view>
    </view>
    <van-steps steps="{{steps}}" active="{{currentStep - 1}}" />
  </view>

  <!-- ===== STEP 1: 输入手机号 ===== -->
  <view class="card step-card" wx:if="{{currentStep === 1}}">
    <view class="step-header">
      <text class="step-num-badge">Step 1</text>
      <text class="step-title">输入手机号</text>
    </view>
    <view class="step-content">
      <view class="input-group">
        <text class="input-label">手机号码</text>
        <van-field
          class="input-wrapper {{step1PhoneError ? 'input-error' : ''}}"
          value="{{step1Phone}}"
          placeholder="请输入11位手机号码"
          type="digit"
          maxlength="11"
          disabled="{{currentStep > 1}}"
          error="{{!!step1PhoneError}}"
          error-message="{{step1PhoneError}}"
          bind:change="onPhoneInput"
        />
      </view>
      <van-button
        type="primary"
        block
        bind:tap="submitPhone"
        wx:if="{{currentStep === 1}}"
        disabled="{{!step1Phone || step1Phone.length < 11}}"
      >提交核验</van-button>
    </view>
  </view>

  <!-- ===== STEP 2: 等待资格核验 ===== -->
  <view class="card step-card" wx:if="{{currentStep === 2}}">
    <view class="step-header">
      <text class="step-num-badge">Step 2</text>
      <text class="step-title">资格核验中</text>
    </view>
    <view class="step-content center">
      <van-loading type="spinner" size="60rpx" />
      <text class="waiting-text">正在查询您的合约办理资格</text>
      <text class="waiting-hint">预计等待 1-2 分钟，请耐心等待...</text>
    </view>
  </view>

  <!-- ===== STEP 3: 核验通过 - 填写收货信息 ===== -->
  <view class="card step-card" wx:if="{{currentStep === 3}}">
    <view class="step-header success">
      <text class="step-num-badge">Step 3</text>
      <text class="step-title">资格核验通过</text>
    </view>
    <view class="step-content">
      <!-- 重要提示 -->
      <view class="notice-box warning">
        <text class="notice-text">重要提示：合约办理涉及终端与合约绑定，一旦办理不支持无理由退换货</text>
      </view>

      <view class="input-group">
        <text class="input-label">姓名</text>
        <van-field
          class="input-wrapper {{formData.nameError ? 'input-error' : ''}}"
          value="{{formData.name}}"
          placeholder="请输入收货人姓名"
          type="text"
          error="{{!!formData.nameError}}"
          error-message="{{formData.nameError}}"
          bind:change="onNameInput"
        />
      </view>

      <view class="input-group">
        <text class="input-label">详细地址</text>
        <van-field
          class="input-wrapper {{formData.addressError ? 'input-error' : ''}}"
          value="{{formData.address}}"
          placeholder="省市区+详细地址"
          type="text"
          error="{{!!formData.addressError}}"
          error-message="{{formData.addressError}}"
          bind:change="onAddressInput"
        />
      </view>

      <view class="input-group">
        <text class="input-label">办理门店</text>
        <view class="picker-field" bindtap="showStorePickerPopup">
          <text>{{formData.storeName || '请选择门店'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </view>

      <view class="checkbox-group">
        <van-checkbox-group value="{{agreed ? ['agreed'] : []}}" bind:change="onAgreeChange">
          <van-checkbox name="agreed" shape="square">
            <text class="checkbox-text">我已了解并同意本活动一经办理不支持无理由退换货的要求</text>
          </van-checkbox>
        </van-checkbox-group>
      </view>

      <van-button
        type="primary"
        block
        bind:tap="submitOrderInfo"
        disabled="{{!agreed || !formData.name || !formData.address}}"
      >确认提交</van-button>
    </view>
  </view>

  <!-- ===== STEP 4: 等待验证码 ===== -->
  <view class="card step-card" wx:if="{{currentStep === 4}}">
    <view class="step-header">
      <text class="step-num-badge">Step 3</text>
      <text class="step-title">填写验证码</text>
    </view>
    <view class="step-content">
      <view class="sms-notice">
        <text class="sms-notice-text">我们已为您提交合约申请，中国移动将向您的手机</text>
        <text class="sms-phone">{{maskPhone}}</text>
        <text class="sms-notice-text">发送一条验证码短信，请注意查收。</text>
      </view>
      <view class="input-group">
        <text class="input-label">短信验证码</text>
        <van-field
          class="input-wrapper {{smsCodeError ? 'input-error' : ''}}"
          value="{{smsCode}}"
          placeholder="请输入6位验证码"
          maxlength="6"
          error="{{!!smsCodeError}}"
          error-message="{{smsCodeError}}"
          bind:change="onSmsCodeInput"
        />
      </view>

      <view class="sms-tip">
        <text class="tip-text">此验证码由中国移动系统发送，请勿分享给他人</text>
      </view>

      <!-- 验证码过期提示 -->
      <view class="sms-expire-tip" bindtap="onResendSmsCode">
        <text class="sms-expire-text">验证码已过期？</text>
        <text class="sms-expire-action">点击查看解决方案</text>
      </view>

      <van-button
        type="primary"
        block
        bind:tap="submitSmsCode"
        disabled="{{smsCode.length < 6}}"
      >提交验证码</van-button>
    </view>
  </view>

  <!-- ===== STEP 5: 合约办理中 ===== -->
  <view class="card step-card" wx:if="{{currentStep === 5}}">
    <view class="step-header">
      <text class="step-num-badge">Step 5</text>
      <text class="step-title">合约办理中</text>
    </view>
    <view class="step-content center">
      <van-loading type="spinner" size="60rpx" />
      <text class="waiting-text">管理员正在为您办理合约</text>
      <text class="waiting-hint">预计等待 3-5 分钟...</text>
      <van-button type="default" plain size="small" class="detail-link-btn" bind:tap="goToContractDetail">查看合约详情</van-button>
    </view>
  </view>

  <!-- ===== STEP 6: 合约办理成功 ===== -->
  <view class="card step-card" wx:if="{{currentStep >= 6}}">
    <view class="step-header success">
      <text class="step-title">合约办理成功</text>
    </view>
    <view class="step-content">
      <!-- 权益礼包卡片 -->
      <view class="gift-card">
        <view class="gift-title">您已获得权益礼包</view>
        <view class="gift-items">
          <view class="gift-item">
            <text class="gift-name">智能终端</text>
          </view>
          <view class="gift-item">
            <text class="gift-name">门店服务代金券</text>
          </view>
        </view>
      </view>

      <!-- 发货状态提示 -->
      <view class="delivery-status-box" wx:if="{{contractStatus === 5}}">
        <text class="delivery-status-text">合约已办理，等待发货中</text>
      </view>

      <!-- 快递信息（已发货才显示） -->
      <view class="delivery-card" wx:if="{{contractInfo.trackingNo && contractStatus >= 6}}">
        <view class="delivery-header">
          <text class="delivery-title">快递信息</text>
        </view>
        <view class="delivery-info">
          <view class="delivery-company">{{expressCompanyName}}</view>
          <view class="delivery-no">{{contractInfo.trackingNo}}</view>
          <van-button size="small" plain type="primary" bind:tap="onCopyTrackingNo">复制单号</van-button>
        </view>
      </view>

      <!-- 按钮组 -->
      <view class="btn-group">
        <van-button type="default" plain block bind:tap="goToContractDetail">查看合约详情</van-button>
        <van-button type="primary" plain block bind:tap="goToCoupon">查看我的卡包</van-button>
      </view>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tip" wx:if="{{currentStep < 6}}">
    <text>如有疑问，请联系门店工作人员</text>
  </view>

  <!-- Vant Toast -->
  <van-toast id="van-toast" />

  <!-- 门店选择弹窗（独立于步骤渲染） -->
  <van-popup show="{{showStorePicker}}" position="bottom" bind:close="hideStorePicker">
    <van-picker
      columns="{{storeNames}}"
      show-toolbar
      title="选择门店"
      bind:confirm="onStorePickerConfirm"
      bind:cancel="hideStorePicker"
    />
  </van-popup>

  </block><!-- end pageLoading wrapper -->
</view>
